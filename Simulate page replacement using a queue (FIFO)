#include <stdio.h>

int main()
{
    int frame[3] = {-1,-1,-1};
    int pages[] = {1,2,3,4,1};
    int i, j, k = 0;

    for(i = 0; i < 5; i++)
    {
        frame[k] = pages[i];
        k = (k + 1) % 3;

        for(j = 0; j < 3; j++)
            printf("%d ", frame[j]);

        printf("\n");
    }

    return 0;
}
